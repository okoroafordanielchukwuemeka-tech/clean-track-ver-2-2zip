JWT_SECRET = "30d6c734dab65b4f1df99883362a32dbaa224653a2df7e1702d4df433751bea9a4da766ed2813689e0e1ab6455811a3b"
ALLOWED_ORIGINS = "https://54ceb042-df2e-4668-b5ae-395a11b064db-00-34104mr4upc9h.picard.replit.dev"
