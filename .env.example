# ============================================================
# CleanTrack — Environment Variables Reference
# ============================================================
# Copy this file to .env (never commit .env) or set these
# values in Replit Secrets / your deployment environment.
#
# REQUIRED variables: the server refuses to start without them.
# OPTIONAL variables: logged as warnings if missing.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# In Replit: automatically set when a PostgreSQL database is attached.
DATABASE_URL=postgresql://user:password@localhost:5432/cleantrack

# JWT signing secret — used for owner tokens (7d), worker tokens (12h), admin tokens (8h)
# Must be at least 32 characters. Generate with: openssl rand -hex 48
JWT_SECRET=

# Session integrity secret — used for session signing
# Must be at least 32 characters. Generate with: openssl rand -hex 48
SESSION_SECRET=

# Backup encryption and manifest signing secret
# Used for AES-256-CBC encryption of backup files and HMAC-SHA256 manifest signing.
# Must be at least 32 characters. Generate with: openssl rand -hex 48
BACKUP_SECRET=

# ── OPTIONAL (recommended in production) ─────────────────────

# Comma-separated list of allowed CORS origins
# REQUIRED in production (NODE_ENV=production). Not required in development.
# Example: https://app.cleantrack.ng,https://www.cleantrack.ng
ALLOWED_ORIGINS=

# Meta webhook verify token (for GET challenge during WhatsApp webhook registration)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Meta App Secret — used to verify X-Hub-Signature-256 on inbound WhatsApp webhooks
# Find this in Meta Developer Console → Your App → Settings → Basic → App Secret
# STRONGLY recommended in production to prevent spoofed webhook payloads.
WHATSAPP_APP_SECRET=

# ── OFF-SITE BACKUPS ─────────────────────────────────────────
# Set BACKUP_OFFSITE_PROVIDER to activate encrypted off-site backup uploads.
# Backups are AES-256-CBC encrypted before upload.
# Supported values: r2 | s3 | b2

BACKUP_OFFSITE_PROVIDER=

# Cloudflare R2 (when BACKUP_OFFSITE_PROVIDER=r2)
# Find these in Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cleantrack-backups

# AWS S3 (when BACKUP_OFFSITE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=cleantrack-backups

# Backblaze B2 (when BACKUP_OFFSITE_PROVIDER=b2)
# B2_ENDPOINT format: https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=
B2_APP_KEY=
B2_ENDPOINT=
B2_BUCKET_NAME=cleantrack-backups

# ── RUNTIME (set automatically by Replit — do not set manually) ──
# DATABASE_URL      — set by Replit PostgreSQL integration
# REPLIT_DOMAINS    — your repl's public domain
# REPL_ID           — unique repl identifier

# ── DEVELOPMENT ONLY ─────────────────────────────────────────

# Node environment — controls production-mode checks
# Values: development | test | production
NODE_ENV=development

# API server port (default: 3001)
PORT=3001
