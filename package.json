{
  "name": "clean-track-workspace",
  "private": true,
  "scripts": {
    "dev": "bash start.sh",
    "build": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/clean-track build",
    "db:push": "pnpm --filter @workspace/db push",
    "db:push-force": "pnpm --filter @workspace/db push-force",
    "db:migrate:generate": "pnpm --filter @workspace/db generate",
    "db:migrate": "pnpm --filter @workspace/db migrate",
    "db:migrate:check": "pnpm --filter @workspace/db migrate:check",
    "db:migrate:status": "node scripts/db-migrate-status.mjs",
    "db:backup": "bash scripts/backup.sh ./backups",
    "db:verify-backup": "bash scripts/verify-backup.sh",
    "db:restore": "bash scripts/restore.sh"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "catalog": {
      "drizzle-orm": "^0.42.0",
      "zod": "^3.24.4",
      "@types/node": "^22.15.21"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
